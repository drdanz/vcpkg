{
  "name": "gammaray",
  "version": "3.2.0",
  "description": "GammaRay is a software introspection tool for Qt applications.",
  "homepage": "https://github.com/KDAB/GammaRay",
  "license": "GPL-2.0-or-later",
  "dependencies": [
    {
      "name": "qtbase",
      "default-features": false,
      "features": [
        "gui",
        "network"
      ]
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "3dinspector-probe": {
      "description": "Build 3dinspector probe plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "core-probes",
            "qml-probe",
            "quick-probe"
          ]
        },
        {
          "name": "qt3d",
          "default-features": false,
          "features": [
            "animation",
            "extras",
            "input",
            "logic",
            "qml",
            "render"
          ]
        },
        {
          "name": "qtbase",
          "default-features": false,
          "features": [
            "concurrent"
          ]
        },
        "qtquick3d"
      ]
    },
    "3dinspector-ui": {
      "description": "Build 3dinspector UI plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "3dinspector-probe",
            "ui-parts"
          ]
        }
      ]
    },
    "bluetooth-probe": {
      "description": "Build bluetooth probe plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "core-probes"
          ]
        },
        "qtconnectivity"
      ]
    },
    "cli-injector": {
      "description": "Build command line injector on Windows",
      "supports": "windows"
    },
    "core-probes": {
      "description": "Build core probes plugins"
    },
    "export-svg": {
      "description": "Build widget SVG export support",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "ui-parts"
          ]
        },
        "qtsvg"
      ]
    },
    "export-ui": {
      "description": "Build widget .ui file export support",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "ui-parts"
          ]
        },
        {
          "name": "qttools",
          "default-features": false,
          "features": [
            "designer"
          ]
        }
      ]
    },
    "launcher": {
      "description": "Build gammaray launcher",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "ui-parts"
          ]
        },
        {
          "name": "qtbase",
          "default-features": false,
          "features": [
            "concurrent"
          ]
        }
      ]
    },
    "opengl-probe": {
      "description": "Build OpenGL probe plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "core-probes"
          ]
        },
        {
          "name": "qtbase",
          "default-features": false,
          "features": [
            "opengl"
          ]
        }
      ]
    },
    "positioning-probe": {
      "description": "Build positioning probe plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "core-probes"
          ]
        },
        "qtpositioning"
      ]
    },
    "positioning-ui": {
      "description": "Build positioning UI plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "positioning-probe",
            "quick-probe",
            "ui-parts"
          ]
        },
        "qtlocation"
      ]
    },
    "qml-probe": {
      "description": "Build qml probe plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "core-probes",
            "widgets-probes"
          ]
        },
        "qtdeclarative"
      ]
    },
    "qml-ui": {
      "description": "Build qml UI plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "qml-probe",
            "ui-parts"
          ]
        }
      ]
    },
    "quick-probe": {
      "description": "Build quick inspector probe plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "opengl-probe",
            "qml-probe"
          ]
        }
      ]
    },
    "quick-ui": {
      "description": "Build quick inspector UI plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "quick-probe",
            "ui-parts"
          ]
        }
      ]
    },
    "statemachine-probe": {
      "description": "Build state machine probe plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "core-probes"
          ]
        },
        "qtscxml"
      ]
    },
    "ui-parts": {
      "description": "Build UI parts plugins",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "widgets"
          ]
        }
      ]
    },
    "wlcompositor-probe": {
      "description": "Build Wayland compositor inspector probe plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "widgets"
          ]
        },
        "qtwayland",
        "wayland"
      ],
      "supports": "!(windows | osx)"
    },
    "widgets-probes": {
      "description": "Build Probes",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "core-probes",
            "widgets"
          ]
        }
      ]
    },
    "webinspector-ui": {
      "description": "Build web inspector ui plugin",
      "dependencies": [
        {
          "name": "gammaray",
          "default-features": false,
          "features": [
            "core-probes",
            "ui-parts"
          ]
        },
        "qtwebengine"
      ],
      "supports": "!windows"
      },
    "widgets": {
      "description": "Build widgets support plugin",
      "dependencies": [
        {
          "name": "qtbase",
          "default-features": false,
          "features": [
            "widgets"
          ]
        }
      ]
    }
  }
}
